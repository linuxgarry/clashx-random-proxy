# PostgreSQL（写真值时不要把这文件 commit 到 git）
PG_HOST=192.168.5.20
PG_PORT=5432
PG_USER=garry
PG_PASSWORD=changeme
PG_DB=proxy

# mihomo
MIHOMO_SECRET=

# 端口段 / TTL
PORT_MIN=10000
PORT_MAX=19999
TTL_SECONDS=300

# 测活
DAILY_CRON=0 3 * * *
TEST_CONCURRENCY=100
TEST_TIMEOUT_MS=5000

# 网络（unraid 上 macvlan 父接口通常是 br0 或 eth0）
MACVLAN_PARENT=br0
LAN_SUBNET=192.168.5.0/24
LAN_GATEWAY=192.168.5.1
